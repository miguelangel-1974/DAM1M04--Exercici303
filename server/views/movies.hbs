<!DOCTYPE html>
<html lang="ca">
<head>
  {{> header}}
  <title>Pel·lícules</title>
</head>
<body>
  {{> menu}}

  <main class="container">
    <h1>Llistat de Pel·lícules</h1>

    <a href="/movieAdd">+ Afegir pel·lícula</a>
    <br><br>

    <table class="table">
      <thead>
        <tr>
          <th>Títol</th>
          <th>Descripció</th>
          <th>Actors</th>
          <th>Accions</th>
        </tr>
      </thead>
      <tbody>
        {{#each movies}}
          <tr>
            <td><strong>{{title}}</strong> ({{release_year}})</td>
            <td>{{description}}</td>
            <td>{{actors}}</td>
            <td><a href="/movie/{{film_id}}">Veure fitxa</a></td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </main>

  {{> footer}}
</body>
</html>