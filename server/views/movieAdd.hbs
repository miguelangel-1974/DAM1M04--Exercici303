<!DOCTYPE html>
<html lang="ca">
<head>
  {{> header}}
  <title>Afegir Pel·lícula</title>
</head>
<body>
  {{> menu}}

  <main class="container">
    <h1>Afegir Pel·lícula</h1>

    <form action="/afegirPeli" method="POST">
      <table>
        <tr>
          <td><label>Títol:</label></td>
          <td><input type="text" name="title" required></td>
        </tr>
        <tr>
          <td><label>Descripció:</label></td>
          <td><textarea name="description" rows="3" cols="40"></textarea></td>
        </tr>
        <tr>
          <td><label>Any:</label></td>
          <td><input type="number" name="release_year" min="1900" max="2100"></td>
        </tr>
        <tr>
          <td><label>Idioma:</label></td>
          <td>
            <select name="language_id">
              {{#each languages}}
                <option value="{{language_id}}">{{name}}</option>
              {{/each}}
            </select>
          </td>
        </tr>
        <tr>
          <td><label>Durada (minuts):</label></td>
          <td><input type="number" name="length" min="1"></td>
        </tr>
        <tr>
          <td><label>Classificació:</label></td>
          <td>
            <select name="rating">
              <option value="G">G</option>
              <option value="PG">PG</option>
              <option value="PG-13">PG-13</option>
              <option value="R">R</option>
              <option value="NC-17">NC-17</option>
            </select>
          </td>
        </tr>
        <tr>
          <td></td>
          <td>
            <button type="submit">Afegir</button>
            &nbsp;
            <a href="/movies">Cancel·lar</a>
          </td>
        </tr>
      </table>
    </form>
  </main>

  {{> footer}}
</body>
</html>
