<!DOCTYPE html>
<html lang="ca">
<head>
  {{> header}}
  <title>Editar: {{movie.title}}</title>
</head>
<body>
  {{> menu}}

  <main class="container">
    <h1>Editar: {{movie.title}}</h1>

    <form method="POST" action="/editarPeli">
      <input type="hidden" name="film_id" value="{{movie.film_id}}">

      <label>Títol:</label><br>
      <input type="text" name="title" value="{{movie.title}}" required><br><br>

      <label>Descripció:</label><br>
      <textarea name="description" rows="3" cols="40">{{movie.description}}</textarea><br><br>

      <label>Any:</label><br>
      <input type="number" name="release_year" value="{{movie.release_year}}"><br><br>

      <label>Rating:</label><br>
      <select name="rating">
        <option value="G" {{#if (eq movie.rating 'G')}}selected{{/if}}>G</option>
        <option value="PG" {{#if (eq movie.rating 'PG')}}selected{{/if}}>PG</option>
        <option value="PG-13" {{#if (eq movie.rating 'PG-13')}}selected{{/if}}>PG-13</option>
        <option value="R" {{#if (eq movie.rating 'R')}}selected{{/if}}>R</option>
        <option value="NC-17" {{#if (eq movie.rating 'NC-17')}}selected{{/if}}>NC-17</option>
      </select><br><br>

      <label>Idioma:</label><br>
      <select name="language_id">
        {{#each languages}}
          <option value="{{language_id}}" {{#if (eq language_id ../movie.language_id)}}selected{{/if}}>{{name}}</option>
        {{/each}}
      </select><br><br>

      <button type="submit">Guardar canvis</button>
    </form>

    <br>

    <form method="POST" action="/esborrarPeli">
      <input type="hidden" name="film_id" value="{{movie.film_id}}">
      <button type="submit" onclick="return confirm('Segur que vols esborrar aquesta pel·lícula?')">Esborrar pel·lícula</button>
    </form>

    <br>
    <a href="/movie?id={{movie.film_id}}">Tornar a la fitxa</a>
  </main>

  {{> footer}}
</body>
</html>