<!DOCTYPE html>
<html lang="ca">
<head>
  {{> header}}
  <title>Editar: {{movie.title}}</title>
</head>
<body>
  {{> menu}}

  <main class="container">
    <h1>Editar: {{movie.title}}</h1>

    <!-- Formulari editar -->
    <form action="/editarPeli" method="POST">
      <input type="hidden" name="film_id" value="{{movie.film_id}}">

      <table>
        <tr>
          <td><label>Títol:</label></td>
          <td><input type="text" name="title" value="{{movie.title}}" required></td>
        </tr>
        <tr>
          <td><label>Descripció:</label></td>
          <td><textarea name="description" rows="3" cols="40">{{movie.description}}</textarea></td>
        </tr>
        <tr>
          <td><label>Any:</label></td>
          <td><input type="number" name="release_year" value="{{movie.release_year}}" min="1900" max="2100"></td>
        </tr>
        <tr>
          <td><label>Idioma:</label></td>
          <td>
            <select name="language_id">
              {{#each languages}}
                <option value="{{language_id}}" {{#if (eq language_id ../movie.language_id)}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </select>
          </td>
        </tr>
        <tr>
          <td><label>Durada (minuts):</label></td>
          <td><input type="number" name="length" value="{{movie.length}}" min="1"></td>
        </tr>
        <tr>
          <td><label>Classificació:</label></td>
          <td>
            <select name="rating">
              <option value="G" {{#if (eq movie.rating "G")}}selected{{/if}}>G</option>
              <option value="PG" {{#if (eq movie.rating "PG")}}selected{{/if}}>PG</option>
              <option value="PG-13" {{#if (eq movie.rating "PG-13")}}selected{{/if}}>PG-13</option>
              <option value="R" {{#if (eq movie.rating "R")}}selected{{/if}}>R</option>
              <option value="NC-17" {{#if (eq movie.rating "NC-17")}}selected{{/if}}>NC-17</option>
            </select>
          </td>
        </tr>
        <tr>
          <td></td>
          <td>
            <button type="submit">Guardar canvis</button>
            &nbsp;
            <a href="/movie/{{movie.film_id}}">Cancel·lar</a>
          </td>
        </tr>
      </table>
    </form>

    <br><hr><br>

    <!-- Formulari esborrar -->
    <form action="/esborrarPeli" method="POST" onsubmit="return confirm('Segur que vols esborrar aquesta pel·lícula?')">
      <input type="hidden" name="film_id" value="{{movie.film_id}}">
      <button type="submit" class="btn-delete">🗑️ Esborrar pel·lícula</button>
    </form>
  </main>

  {{> footer}}
</body>
</html>
